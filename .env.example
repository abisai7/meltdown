# Meltdown — Environment Variables (all optional)

# Comma-separated origins for CORS (default: "*" for local dev)
# ALLOWED_ORIGINS=https://your-app.up.railway.app

# API key auth — set to require X-API-Key header (default: open, no auth)
# Generate one with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# API_KEY=your-secret-key-here

# Max seconds per conversion (default: 30)
# CONVERSION_TIMEOUT=30

# Max simultaneous conversions (default: 5)
# MAX_CONCURRENT=5

# Rate limit per IP (default: 10/minute)
# RATE_LIMIT=10/minute
